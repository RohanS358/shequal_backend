# =============================================
# CoPaila Backend — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# ----- DATABASE (Neon PostgreSQL) -----
# Get this from: https://neon.tech → your project → Connection string
DATABASE_URL="postgresql://neondb_owner:npg_2TyYHFpL5Vmn@ep-mute-union-ad2qkdg0-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ----- JWT AUTH -----
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="15m"

JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- APP -----
PORT=5000

# On Render, PORT is set automatically — do NOT hardcode 3000 in production

# ----- CORS -----
# Frontend URL (Vercel deployment or localhost for dev)
FRONTEND_URL="shequalfrontend.vercel.app"
# For production: FRONTEND_URL="https://your-app.vercel.app"

# ----- REGISTRATION DRAFT TTL -----
# How long (in hours) a multi-step registration draft is valid before expiry
DRAFT_TTL_HOURS=24

# =============================================
# FRONTEND ENVIRONMENT VARIABLES
# Add these to LeafNode/.env (or Vercel settings)
# =============================================
# VITE_API_BASE_URL=http://localhost:3000
# VITE_API_BASE_URL=https://your-backend.onrender.com   ← production